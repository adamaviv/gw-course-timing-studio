{
  "name": "class-schedule-visual",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "test": "npm run test:security",
    "test:security": "npm run test:security-deps && npm run test:security-phase1 && npm run test:security-phase2 && npm run test:security-phase3 && npm run test:security-phase4 && npm run test:security-phase5 && npm run test:security-phase6 && npm run test:security-phase7 && npm run test:security-phase8 && npm run test:security-phase9 && npm run test:security-phase10 && npm run test:security-phase12",
    "test:search-dsl": "node scripts/search-dsl-tests.mjs",
    "test:usability": "node scripts/search-dsl-tests.mjs && node scripts/usability-audit-tests.mjs",
    "test:security-deps": "npm audit --omit=dev --audit-level=high",
    "test:security-phase1": "node scripts/security-phase1-tests.mjs",
    "test:security-phase2": "node scripts/security-phase2-tests.mjs",
    "test:security-phase3": "node scripts/security-phase3-tests.mjs",
    "test:security-phase4": "node scripts/security-phase4-tests.mjs",
    "test:security-phase5": "node scripts/security-phase5-tests.mjs",
    "test:security-phase6": "node scripts/security-phase6-tests.mjs",
    "test:security-phase7": "node scripts/security-phase7-tests.mjs",
    "test:security-phase8": "node scripts/security-phase8-tests.mjs",
    "test:security-phase9": "node scripts/security-phase9-tests.mjs",
    "test:security-phase10": "node scripts/security-phase10-tests.mjs",
    "test:security-phase12": "node scripts/security-phase12-tests.mjs"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase": "^12.10.0",
    "helmet": "^8.1.0",
    "lz-string": "^1.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "playwright": "^1.58.2",
    "vite": "^7.1.7"
  },
  "overrides": {
    "undici": "^7.24.0"
  }
}

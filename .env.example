# Comma-separated list of frontend origins allowed to call the API.
# Use explicit origins only (scheme + host + optional port), no trailing slash.
# Example:
# ALLOWED_ORIGINS=http://localhost:8787,https://your-app.example.com
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787

# Express trust proxy behavior.
# false/0/off (recommended default): do not trust x-forwarded-* headers.
# true/1/on or subnet/hop values: trust a known proxy deployment.
TRUST_PROXY=0

# CORS preflight cache max age (seconds)
CORS_MAX_AGE_SECONDS=600

# Upstream request timeout and max response size controls
UPSTREAM_FETCH_TIMEOUT_MS=10000
UPSTREAM_MAX_RESPONSE_BYTES=2097152

# Per-client API rate limiting window and thresholds
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_PARSE_MAX=30
API_RATE_LIMIT_SUBJECTS_MAX=60
API_RATE_LIMIT_BUCKET_CAP=5000

# Production log redaction control.
# 0 (recommended): redact unknown server error details in logs.
# 1: include raw error messages + stacks for deep debugging.
LOG_API_ERROR_DETAILS=0

# Firebase configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
